.log-http .log-level { background: #3b82f6; color: white; }
.log-debug .log-level { background: #8b5cf6; color: white; }

.log-time {
  color: #666;
  font-size: 11px;
}

.log-vendor {
  color: #f59e0b;
  font-size: 11px;
}

.log-service {
  color: #06b6d4;
  font-size: 11px;
}

.log-message {
  color: #e5e5e5;
  cursor: pointer;
  word-break: break-word;
}

.log-message:hover {
  color: #10b981;
}

.log-stack {
  color: #f87171;
  font-size: 11px;
  margin-top: 6px;
  padding-left: 12px;
  border-left: 2px solid #333;
}

.stat-card {
  background: #111;
  padding: 20px;
  border-radius: 12px;
  border: 1px solid #222;
}

.stat-card .stat-label {
  color: #888;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 8px;
}

.stat-card .stat-value {
  font-size: 28px;
  font-weight: 700;
  color: #10b981;
}

.stat-card.error .stat-value { color: #ef4444; }
.stat-card.warn .stat-value { color: #f59e0b; }
.stat-card.info .stat-value { color: #3b82f6; }

.form-label {
  display: block;
  color: #ccc;
  font-size: 14px;
  font-weight: 500;
  margin-bottom: 6px;
}

.form-input {
  width: 100%;
  padding: 10px 14px;
  background: #0a0f0d;
  border: 1px solid #333;
  border-radius: 8px;
  color: #e5e5e5;
  font-size: 14px;
  transition: border-color 0.2s;
}

.form-input:focus {
  outline: none;
  border-color: #10b981;
  box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
}

.btn {
  padding: 10px 20px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: none;
}

.btn-primary {
  background: #10b981;
  color: black;
}

.btn-primary:hover {
  background: #34d399;
}

.btn-secondary {
  background: #333;
  color: #e5e5e5;
}

.btn-secondary:hover {
  background: #444;
}

.btn-outline {
  background: transparent;
  color: #10b981;
  border: 1px solid #10b981;
}

.btn-outline:hover {
  background: rgba(16, 185, 129, 0.1);
}
</style>
