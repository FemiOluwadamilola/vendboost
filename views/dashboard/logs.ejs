  padding: 12px 16px;
  border-bottom: 1px solid #1a1a1a;
  font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
  font-size: 12px;
  line-height: 1.6;
  transition: background 0.2s;
}

.log-entry:hover {
  background: #1a1a1a;
}

