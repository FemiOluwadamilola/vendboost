<!-- Main Content -->
<main class="main-content">
    <%- include('../partials/message') %>
    
    <!-- Top Navbar -->
    <nav class="navbar">
        <div class="navbar-left">
            <h1 class="page-title">Dashboard</h1>
            <p class="page-subtitle">Welcome back! Here's what's happening with your store.</p>
        </div>
        <div class="navbar-right">
            <button class="icon-btn" title="Notifications">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
            </button>
            <button class="icon-btn" id="theme-toggle" title="Toggle Theme">
                <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="4"/>
                    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
                </svg>
                <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
            </button>
        </div>
    </nav>

    <!-- Stats Grid -->
    <section class="stats-grid">
        <div class="glass-card stat-card">
            <div class="stat-icon purple">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                </svg>
            </div>
            <div class="stat-content">
                <span class="stat-label">Total Products</span>
                <span class="stat-value"><%= stats.totalProducts || 0 %></span>
            </div>
        </div>

        <div class="glass-card stat-card">
            <div class="stat-icon orange">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
            </div>
            <div class="stat-content">
                <span class="stat-label">Broadcasts Today</span>
                <span class="stat-value"><%= stats.broadcasts || 0 %></span>
            </div>
        </div>

        <div class="glass-card stat-card">
            <div class="stat-icon green">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
            <div class="stat-content">
                <span class="stat-label">New Leads Today</span>
                <span class="stat-value"><%= stats.newLeadsToday || 0 %></span>
            </div>
        </div>

        <div class="glass-card stat-card">
            <div class="stat-icon blue">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
            </div>
            <div class="stat-content">
                <span class="stat-label">Converted</span>
                <span class="stat-value"><%= stats.converted || 0 %></span>
            </div>
        </div>
    </section>

    <!-- Quick Actions -->
    <section class="quick-actions">
        <h2 class="section-title">Quick Actions</h2>
        <div class="actions-grid">
            <a href="/dashboard/new-product" class="action-card">
                <div class="action-icon" style="background: linear-gradient(135deg, #8B5CF6, #6366F1);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                </div>
                <span>Add Product</span>
            </a>
            <a href="/dashboard/products" class="action-card">
                <div class="action-icon" style="background: linear-gradient(135deg, #F59E0B, #EF4444);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                        <polyline points="22,6 12,13 2,6"/>
                    </svg>
                </div>
                <span>Broadcast</span>
            </a>
            <a href="/dashboard/leads" class="action-card">
                <div class="action-icon" style="background: linear-gradient(135deg, #10B981, #059669);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                    </svg>
                </div>
                <span>View Leads</span>
            </a>
            <a href="/dashboard/settings" class="action-card">
                <div class="action-icon" style="background: linear-gradient(135deg, #3B82F6, #2563EB);">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </div>
                <span>Settings</span>
            </a>
        </div>
    </section>

    <!-- Content Split -->
    <div class="content-split">
        <!-- Recent Leads -->
        <section class="glass-card table-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">Recent Leads</h2>
                    <p class="card-subtitle">Latest customer inquiries</p>
                </div>
                <a href="/dashboard/leads" class="card-btn">View All</a>
            </div>
            <div class="leads-list">
                <% if (leads && leads.length > 0) { %>
                    <% leads.slice(0, 5).forEach(lead => { %>
                        <div class="lead-item">
                            <div class="lead-avatar">
                                <%= lead.customerName ? lead.customerName.charAt(0).toUpperCase() : 'U' %>
                            </div>
                            <div class="lead-info">
                                <span class="lead-name"><%= lead.customerName || 'Unknown' %></span>
                                <span class="lead-phone"><%= lead.customerNumber %></span>
                            </div>
                            <div class="lead-meta">
                                <span class="lead-intent <%= lead.intentType || 'inquiry' %>"><%= lead.intentType || 'inquiry' %></span>
                                <span class="lead-time"><%= new Date(lead.createdAt).toLocaleDateString() %></span>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="empty-state">
                        <p>No leads yet. Start by connecting WhatsApp!</p>
                    </div>
                <% } %>
            </div>
        </section>

        <!-- Recent Products -->
        <section class="glass-card table-card">
            <div class="card-header">
                <div>
                    <h2 class="card-title">Recent Products</h2>
                    <p class="card-subtitle">Your product inventory</p>
                </div>
                <a href="/dashboard/products" class="card-btn">View All</a>
            </div>
            <div class="products-list">
                <% if (products && products.length > 0) { %>
                    <% products.slice(0, 5).forEach(product => { %>
                        <div class="product-item">
                            <div class="product-image">
                                <% if (product.image) { %>
                                    <img src="/vendor-product-img/<%= typeof vendor !== 'undefined' && vendor.businessName ? vendor.businessName : 'default' %>/<%= product.image %>" alt="<%= product.name %>">
                                <% } else { %>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                        <circle cx="8.5" cy="8.5" r="1.5"/>
                                        <polyline points="21 15 16 10 5 21"/>
                                    </svg>
                                <% } %>
                            </div>
                            <div class="product-info">
                                <span class="product-name"><%= product.name %></span>
                                <span class="product-price">₦<%= product.price %></span>
                            </div>
                            <div class="product-actions">
                                <button class="icon-btn-sm" onclick="postToStatus('<%= product._id %>')" title="Post to Status">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                        <polyline points="22,6 12,13 2,6"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="empty-state">
                        <p>No products yet. <a href="/dashboard/new-product">Add your first product!</a></p>
                    </div>
                <% } %>
            </div>
        </section>
    </div>
</main>