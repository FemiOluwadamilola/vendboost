<!-- Main Content -->
<main class="main-content">
    <!-- Top Navbar -->
    <nav class="navbar">
        <h1 class="page-title">VendBoost Dashboard 🚀</h1>
        <div class="navbar-right">
            <button class="nav-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
                <span class="notification-dot"></span>
            </button>
            <button class="nav-btn" id="theme-toggle" title="Toggle Light/Dark Mode">
                <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="4"/>
                    <path d="M12 2v2"/><path d="M12 20v2"/>
                    <path d="M4.93 4.93l1.41 1.41"/><path d="M17.66 17.66l1.41 1.41"/>
                    <path d="M2 12h2"/><path d="M20 12h2"/>
                    <path d="M6.34 17.66l-1.41 1.41"/><path d="M19.07 4.93l-1.41 1.41"/>
                </svg>
                <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
            </button>
        </div>
    </nav>

    <!-- Stats Cards -->
    <section class="stats-grid">
        <div class="glass-card glass-card-3d stat-card">
            <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Total Products</h3>
                    <div class="stat-value"><%= stats.totalProducts || 0 %></div>
                </div>
            </div>
        </div>

        <div class="glass-card glass-card-3d stat-card">
             <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Status Posts</h3>
                    <div class="stat-value"><%= stats.statusPosts || 0 %></div>
                </div>
            </div>
        </div>

        <div class="glass-card glass-card-3d stat-card">
             <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Broadcast Sent</h3>
                    <div class="stat-value"><%= stats.broadcasts || 0 %></div>
                </div>
            </div>
        </div>

        <div class="glass-card glass-card-3d stat-card">
           <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Leads Generated</h3>
                    <div class="stat-value"><%= stats.leads || 0 %></div>
                </div>
            </div>
        </div>
    </section>

     <!-- QUICK ACTIONS -->
    <section class="content-grid" style="grid-template-columns: repeat(3, 1fr);">

        <div class="glass-card quick-card">
            <h3>📤 Post to Status</h3>
            <p>Share your products instantly</p>
            <a href="/products" class="card-btn success">Go to Products</a>
        </div>

        <div class="glass-card quick-card">
            <h3>📢 Broadcast</h3>
            <p>Send products to all customers</p>
            <a href="/products" class="card-btn info">Start Broadcast</a>
        </div>

        <div class="glass-card quick-card">
            <h3>💬 Conversations</h3>
            <p>Manage incoming WhatsApp chats</p>
            <a href="/chats" class="card-btn">Open Inbox</a>
        </div>

    </section>

 
    <!-- PRODUCTS PERFORMANCE TABLE -->
    <section class="content-grid" style="grid-template-columns: 1fr;">
        <div class="glass-card table-card">

            <div class="card-header">
                <div>
                    <h2 class="card-title">Top Performing Products</h2>
                    <p class="card-subtitle">Track engagement & sales</p>
                </div>

                <div class="card-actions">
                    <a href="/products" class="card-btn">View All</a>
                </div>
            </div>

            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Views</th>
                            <th>Clicks</th>
                            <th>Leads</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% if (products && products.length > 0) { %>
                            <% products.forEach(product => { %>
                                <tr>

                                    <td>
                                        <div class="table-user">
                                            <img src="/uploads/<%= product.image %>" class="table-avatar"/>
                                            <div class="table-user-info">
                                                <span class="table-user-name"><%= product.name %></span>
                                                <span class="table-user-email">₦<%= product.price %></span>
                                            </div>
                                        </div>
                                    </td>

                                    <td><%= product.views || 0 %></td>
                                    <td><%= product.clicks || 0 %></td>
                                    <td><%= product.leads || 0 %></td>

                                    <td class="table-actions">

                                        <button class="card-btn success"
                                            onclick="postToStatus('<%= product._id %>')">
                                            📤 Status
                                        </button>

                                        <button class="card-btn info"
                                            onclick="broadcastProduct('<%= product._id %>')">
                                            📢 Broadcast
                                        </button>

                                    </td>

                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" style="text-align:center;">
                                    No products yet. Upload your first product 🚀
                                </td>
                            </tr>
                        <% } %>

                    </tbody>
                </table>
            </div>

        </div>
    </section>
</main>