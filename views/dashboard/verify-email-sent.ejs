
    <div class="login-page">
        <!-- Theme Toggle -->
        <button class="theme-toggle-float" id="theme-toggle" title="Toggle Light/Dark Mode">
            <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/>
                <path d="M4.93 4.93l1.41 1.41"/><path d="M17.66 17.66l1.41 1.41"/>
                <path d="M2 12h2"/><path d="M20 12h2"/>
                <path d="M6.34 17.66l-1.41 1.41"/><path d="M19.07 4.93l-1.41 1.41"/>
            </svg>
            <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
        </button>
        <%- include('../partials/message') %>
        <div class="login-container">
            <div class="login-card">
                <div class="login-header">
                    <div class="verification-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </div>
                    <h1 class="login-title">Check Your Email</h1>
                    <p class="login-subtitle">We've sent a verification link to your email address. Please click the link to verify your account.</p>
                </div>

                <div class="verification-instructions">
                    <p>Didn't receive the email?</p>
                    <ul>
                        <li>Check your spam or junk folder</li>
                        <li>Make sure your email address is correct</li>
                    </ul>
                </div>

                <form method="POST" action="/auth/resend-verification">
                    <div class="form-group">
                        <label class="form-label" for="email">Email Address</label>
                        <input type="email" id="email" name="email" class="form-input" placeholder="Enter your email" required>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        Resend Verification Email
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </button>
                </form>

                <p class="login-footer">
                    Already verified? <a href="/signin">Sign In</a>
                </p>
            </div>
        </div>

        <!-- Footer -->
        <footer class="site-footer">
            <p>Copyright © <%= new Date().getFullYear() %> VendBoost. Built for serious vendors. </p>
        </footer>
    </div>

    <style>
        .verification-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .verification-icon svg {
            width: 40px;
            height: 40px;
            color: white;
        }

        .verification-instructions {
            background: rgba(102, 126, 234, 0.1);
            border-radius: 8px;
            padding: 15px 20px;
            margin-bottom: 20px;
            text-align: left;
        }

        .verification-instructions p {
            margin: 0 0 10px;
            font-weight: 600;
            color: #333;
        }

        .verification-instructions ul {
            margin: 0;
            padding-left: 20px;
            color: #666;
        }

        .verification-instructions li {
            margin-bottom: 5px;
        }
    </style>
