<!-- Main Content -->
<main class="main-content">
    <!-- Top Navbar -->
    <nav class="navbar">
        <div class="page-header">
            <h1 class="page-title">Products</h1>
            <div class="page-breadcrumb">
                <a href="index.html">Dashboard</a>
                <span>/</span>
                <span>products</span>
            </div>
        </div>
        <div class="navbar-right">
            <div class="search-box">
                <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input type="text" class="search-input" placeholder="Search products...">
            </div>
            <button class="nav-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
                <span class="notification-dot"></span>
            </button>
            <button class="nav-btn" id="theme-toggle" title="Toggle Light/Dark Mode">
                <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/>
                    <path d="M4.93 4.93l1.41 1.41"/><path d="M17.66 17.66l1.41 1.41"/>
                    <path d="M2 12h2"/><path d="M20 12h2"/>
                    <path d="M6.34 17.66l-1.41 1.41"/><path d="M19.07 4.93l-1.41 1.41"/>
                </svg>
                <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
            </button>
             <a href="/dashboard/new-product" class="card-btn">
                + Add Product
            </a>
        </div>
    </nav>

    <!-- Stats Cards -->
    <section class="stats-grid">
        <div class="glass-card glass-card-3d stat-card">
            <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Total Products</h3>
                    <div class="stat-value">24</div>
                </div>
            </div>
        </div>

        <div class="glass-card glass-card-3d stat-card">
             <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Active Listings</h3>
                    <div class="stat-value">18</div>
                </div>
            </div>
        </div>

        <div class="glass-card glass-card-3d stat-card">
             <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Out of Stock</h3>
                    <div class="stat-value">6</div>
                </div>
            </div>
        </div>

        <div class="glass-card glass-card-3d stat-card">
             <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Total Revenue</h3>
                    <div class="stat-value">₦1.2M</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Product Table -->
    <section class="content-grid" style="grid-template-columns: 1fr;">
        <div class="glass-card table-card" style="grid-column: span 1;">
            <div class="card-header">
                <div>
                    <h2 class="card-title">All Products</h2>
                    <p class="card-subtitle">Manage your product inventory</p>
                </div>
                <div class="card-actions">
                    <a href="/dashboard/new-product" class="card-btn">
                        + Add Product
                    </a>
                </div>
            </div>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% products.forEach(product => { %>
                        <tr>
                            <td>
                                <div class="table-user">
                                    <img src="../vendor-product-img/<%=vendor.businessName %>/<%=product.image%>" alt="<%= product.name %>" class="table-avatar"/>
                                    <div class="table-user-info">
                                        <span class="table-user-name"><%= product.name %></span>
                                        <span class="table-user-email"><%= product.category %></span>
                                    </div>
                                </div>
                            </td>

                            <td>₦<%= product.price %></td>
                            <td><%= product.stock %></td>

                            <td>
                                <span class="status-badge <%= product.stock > 0 ? 'completed' : 'pending' %>">
                                    <%= product.stock > 0 ? 'Available' : 'Out of Stock' %>
                                </span>
                            </td>

                            <td><%= product.createdAt.toDateString() %></td>

                           <td class="table-actions">

                                <!-- Upload to WhatsApp Status -->
                                <button 
                                    class="card-btn success"
                                    onclick="postToStatus('<%= product._id %>')"
                                    title="Post to WhatsApp Status">
                                    📤 Status
                                </button>

                                <!-- Broadcast Product -->
                                <button 
                                    class="card-btn info"
                                    onclick="broadcastProduct('<%= product._id %>')"
                                    title="Send to customers">
                                    📢 Broadcast
                                </button>

                                <!-- Edit -->
                                <a href="/products/edit/<%= product._id %>" class="card-btn">
                                    Edit
                                </a>

                                <!-- Delete -->
                                <button 
                                    class="card-btn danger"
                                    onclick="deleteProduct('<%= product._id %>')">
                                    Delete
                                </button>

                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</main>