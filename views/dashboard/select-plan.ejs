<main class="main-content">
    <%- include('../partials/message') %>
    
    <!-- Header -->
    <nav class="navbar">
        <div class="page-header">
            <h1 class="page-title">Choose a Plan</h1>
            <p class="page-subtitle">Select a plan to connect WhatsApp and start automating your sales</p>
        </div>
    </nav>

    <!-- Info Card -->
    <div class="glass-card" style="margin-bottom: 32px; padding: 24px; border-left: 4px solid var(--emerald);">
        <div style="display: flex; align-items: center; gap: 16px;">
            <div style="width: 48px; height: 48px; background: var(--emerald); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
                    <path d="M20.1 3.9c-.5-.4-1.2-.6-1.9-.6H5.8c-.7 0-1.4.2-1.9.6L2.2 6.5c-.4.4-.6 1-.6 1.6v10.8c0 .7.2 1.3.6 1.7l1.7 1.6c.5.4 1.2.6 1.9.6h10.3c.7 0 1.4-.2 1.9-.6l1.7-1.6c.4-.4.6-1 .6-1.7V5.1c0-.6-.2-1.2-.6-1.6l-.4-.6zM5.8 8h6.6c.3 0 .5.1.5.4v.7c0 .3-.2.5-.5.5H5.8c-.3 0-.5-.2-.5-.5v-.7c0-.3.2-.4.5-.4zm7.7 5.7c0 1.4-1.1 2.5-2.5 2.5s-2.5-1.1-2.5-2.5 1.1-2.5 2.5-2.5 2.5 1.1 2.5 2.5zm1.7 1.7c-.2.2-.5.3-.8.3s-.6-.1-.8-.3l-.9-.9c-.4-.4-.4-1 0-1.4s1-.4 1.4 0l.3.3.9.9c.4.4.4 1 0 1.4z"/>
                </svg>
            </div>
            <div>
                <h3 style="margin-bottom: 4px;">Connect WhatsApp to get started</h3>
                <p style="color: var(--text-muted); font-size: 14px;">Choose a plan below to unlock WhatsApp automation and start capturing leads.</p>
            </div>
        </div>
    </div>

    <!-- Plans Grid -->
    <div class="plans-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;">
        
        <!-- Trial Plan -->
        <div class="glass-card plan-card" style="padding: 24px; border-radius: 16px; position: relative; border: 2px solid var(--emerald);">
            <div style="position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--emerald); color: white; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 600;">FREE</div>
            <div style="text-align: center; margin-bottom: 20px;">
                <h3 style="font-size: 20px; margin-bottom: 8px; color: var(--emerald);">14-Day Trial</h3>
                <p style="font-family: 'Space Mono', monospace; font-size: 28px; font-weight: 700;">₦0</p>
                <p style="color: var(--text-muted); font-size: 12px;">for 14 days</p>
            </div>
            <ul style="list-style: none; padding: 0; margin-bottom: 20px; font-size: 13px;">
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    50 Leads
                </li>
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    20 Broadcasts/Day
                </li>
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    1 WhatsApp Number
                </li>
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    Auto Follow-ups
                </li>
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    Status Posting
                </li>
            </ul>
            <form action="/whatsapp/select-plan" method="POST">
                <input type="hidden" name="plan" value="trial">
                <button type="submit" class="btn btn-primary" style="width: 100%;">Start Free Trial</button>
            </form>
        </div>

        <!-- Starter Plan -->
        <div class="glass-card plan-card" style="padding: 24px; border-radius: 16px; position: relative;">
            <div style="text-align: center; margin-bottom: 20px;">
                <h3 style="font-size: 20px; margin-bottom: 8px;">Starter</h3>
                <p style="font-family: 'Space Mono', monospace; font-size: 28px; font-weight: 700;">₦2,000</p>
                <p style="color: var(--text-muted); font-size: 12px;">per month</p>
            </div>
            <ul style="list-style: none; padding: 0; margin-bottom: 20px; font-size: 13px;">
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    100 Leads
                </li>
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    30 Broadcasts/Day
                </li>
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    1 WhatsApp Number
                </li>
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    Auto Follow-ups
                </li>
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    Status Posting
                </li>
            </ul>
            <form action="/whatsapp/select-plan" method="POST">
                <input type="hidden" name="plan" value="starter">
                <button type="submit" class="btn btn-primary" style="width: 100%;">Select Starter</button>
            </form>
        </div>

        <!-- Pro Plan -->
        <div class="glass-card plan-card" style="padding: 24px; border-radius: 16px; position: relative; border: 2px solid var(--gold);">
            <div style="position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--gold); color: #0a0f0d; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 600;">BEST VALUE</div>
            <div style="text-align: center; margin-bottom: 20px;">
                <h3 style="font-size: 20px; margin-bottom: 8px; color: var(--gold);">Pro</h3>
                <p style="font-family: 'Space Mono', monospace; font-size: 28px; font-weight: 700;">₦5,000</p>
                <p style="color: var(--text-muted); font-size: 12px;">per month</p>
            </div>
            <ul style="list-style: none; padding: 0; margin-bottom: 20px; font-size: 13px;">
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    1,000 Leads
                </li>
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    500 Broadcasts/Day
                </li>
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    1 WhatsApp Number
                </li>
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    Auto Follow-ups
                </li>
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    Status Posting
                </li>
                <li style="padding: 6px 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    Priority Support
                </li>
            </ul>
            <form action="/whatsapp/select-plan" method="POST">
                <input type="hidden" name="plan" value="pro">
                <button type="submit" class="btn btn-primary" style="width: 100%; background: linear-gradient(135deg, var(--gold), var(--amber));">Select Pro</button>
            </form>
        </div>
    </div>

    <!-- Back Link -->
    <div style="text-align: center; margin-top: 32px;">
        <a href="/dashboard" class="btn btn-secondary" style="display: inline-block;">Back to Dashboard</a>
    </div>
</main>