<main class="main-content">
    <%- include('../partials/message') %>
     <!-- Navbar -->
     <nav class="navbar">
        <div class="page-header">
            <h1 class="page-title">Leads & Conversations 💬</h1>
            <div class="page-breadcrumb">
                <a href="/dashboard">Dashboard</a>
                <span>/</span>
                <span>Leads</span>
            </div>
        </div>

        <div class="navbar-right">
            <div class="search-box">
                <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input type="text" class="search-input" placeholder="Search leads..." id="leadSearch">
            </div>
            <div class="filter-group">
                <select class="filter-select" id="leadStatusFilter">
                    <option value="">All Status</option>
                    <option value="new">New</option>
                    <option value="pending">Pending</option>
                    <option value="contacted">Contacted</option>
                    <option value="qualified">Qualified</option>
                    <option value="converted">Converted</option>
                    <option value="failed">Failed</option>
                </select>
            </div>
            <a href="/products" class="card-btn">
                📢 Broadcast Product
            </a>
        </div>
    </nav>

    <!-- VENDBOOST METRICS -->
    <section class="stats-grid">

        <div class="glass-card stat-card">
            <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Total Leads</h3>
                    <div class="stat-value"><%= stats.totalLeads || 0 %></div>
                </div>
            </div>
        </div>

        <div class="glass-card stat-card">
            <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>New Today</h3>
                    <div class="stat-value"><%= stats.newLeads || 0 %></div>
                </div>
            </div>
        </div>

        <div class="glass-card stat-card">
            <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Hot Leads 🔥</h3>
                    <div class="stat-value"><%= stats.hotLeads || 0 %></div>
                </div>
            </div>
        </div>

        <div class="glass-card stat-card">
            <div class="stat-card-inner">
                <div class="stat-info">
                    <h3>Converted</h3>
                    <div class="stat-value"><%= stats.converted || 0 %></div>
                </div>
            </div>
        </div>

    </section>

    <!-- LEADS TABLE -->
    <section class="content-grid" style="grid-template-columns: 1fr;">
        <div class="glass-card table-card">

            <div class="card-header">
                <div>
                    <h2 class="card-title">Incoming Leads</h2>
                    <p class="card-subtitle">People interacting with your products</p>
                </div>

                <div class="card-actions">
                    <button class="card-btn">Export</button>
                </div>
            </div>

            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Customer</th>
                            <th>Product</th>
                            <th>Source</th>
                            <th>Intent</th>
                            <th>Status</th>
                            <th>Time</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% if (leads && leads.length > 0) { %>
                            <% leads.forEach(lead => { %>

                                <tr>

                                    <!-- CUSTOMER -->
                                    <td>
                                        <div class="table-user">
                                            <div class="table-avatar">
                                                <%= lead.customerName ? lead.customerName[0] : "U" %>
                                            </div>
                                            <div class="table-user-info">
                                                <span class="table-user-name">
                                                    <%= lead.customerName || "Unknown" %>
                                                </span>
                                                <span class="table-user-email">
                                                    <%= lead.customerNumber %>
                                                </span>
                                            </div>
                                        </div>
                                    </td>

                                    <!-- PRODUCT -->
                                    <td>
                                        <%= lead.product ? lead.product.name : "N/A" %>
                                    </td>

                                    <!-- SOURCE -->
                                    <td>
                                        <span class="status-badge">
                                            <%= lead.source || "WhatsApp" %>
                                        </span>
                                    </td>

                                    <!-- INTENT -->
                                    <td>
                                        <% if (lead.intentType === "ready-to-pay") { %>
                                            <span class="status-badge completed">💰 Ready</span>
                                        <% } else if (lead.intentType === "price") { %>
                                            <span class="status-badge processing">💲 Price</span>
                                        <% } else if (lead.intentType === "order") { %>
                                            <span class="status-badge completed">🛒 Order</span>
                                        <% } else if (lead.intentType === "negotiation") { %>
                                            <span class="status-badge processing">💬 Negotiation</span>
                                        <% } else { %>
                                            <span class="status-badge pending">💬 Inquiry</span>
                                        <% } %>
                                    </td>

                                    <!-- STATUS -->
                                    <td>
                                        <% const statusClass = lead.status === 'converted' ? 'completed' : lead.status === 'failed' ? 'danger' : 'processing'; %>
                                        <span class="status-badge <%= statusClass %>">
                                            <%= lead.status || "new" %>
                                        </span>
                                    </td>

                                    <!-- TIME -->
                                    <td>
                                        <%= new Date(lead.createdAt).toLocaleString() %>
                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="table-actions">

                                        <!-- Open Chat -->
                                        <a 
                                            href="https://wa.me/<%= lead.customerNumber %>" 
                                            target="_blank"
                                            class="card-btn success">
                                            💬 Chat
                                        </a>

                                        <!-- Mark as Converted -->
                                        <button 
                                            class="card-btn"
                                            onclick="updateLeadStatus('<%= lead._id %>', 'converted')">
                                            ✅ Convert
                                        </button>

                                    </td>

                                </tr>

                            <% }) %>
                        <% } else { %>

                            <tr>
                                <td colspan="7" style="text-align:center;">
                                    No leads yet. Start posting products 🚀
                                </td>
                            </tr>

                        <% } %>

                    </tbody>
                </table>
            </div>

        </div>
    </section>

</main>