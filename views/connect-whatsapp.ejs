<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %> - VendBoost</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --emerald: #10b981;
      --emerald-light: #34d399;
      --glass-bg: rgba(255, 255, 255, 0.05);
      --glass-border: rgba(255, 255, 255, 0.1);
      --glass-hover: rgba(255, 255, 255, 0.08);
      --text-primary: #ffffff;
      --text-secondary: #a1a1aa;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Outfit', sans-serif;
      background: radial-gradient(circle at top, #020617, #000000);
      color: var(--text-primary);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      overflow: hidden;
    }

    /* Background Orbs */
    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.3;
    }

    .orb-1 {
      width: 300px;
      height: 300px;
      background: var(--emerald);
      top: -50px;
      left: -50px;
    }

    .orb-2 {
      width: 300px;
      height: 300px;
      background: #facc15;
      bottom: -50px;
      right: -50px;
    }

    /* Glass Card */
    .card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      padding: 40px;
      border-radius: 20px;
      width: 420px;
      text-align: center;
      z-index: 10;
      transition: 0.3s;
    }

    .card:hover {
      background: var(--glass-hover);
    }

    h2 {
      font-size: 26px;
      margin-bottom: 10px;
    }

    .vendor-id {
      font-size: 13px;
      color: var(--text-secondary);
      margin-bottom: 20px;
    }

    .status {
      margin-top: 20px;
      font-size: 15px;
    }

    .success { color: var(--emerald-light); }
    .error { color: #f87171; }
    .loading { color: var(--text-secondary); }

    /* Spinner */
    .spinner {
      margin: 20px auto;
      width: 45px;
      height: 45px;
      border: 4px solid rgba(255,255,255,0.1);
      border-top: 4px solid var(--emerald-light);
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* Button */
    .btn {
      margin-top: 20px;
      padding: 12px 18px;
      border-radius: 10px;
      border: none;
      background: linear-gradient(135deg, var(--emerald), var(--emerald-light));
      color: #000;
      font-weight: 600;
      cursor: pointer;
      transition: 0.3s;
    }

    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(52, 211, 153, 0.3);
    }

    /* QR */
    img.qr {
      margin-top: 20px;
      width: 220px;
      border-radius: 12px;
      border: 1px solid var(--glass-border);
      padding: 10px;
      background: #fff;
      animation: fadeIn 0.5s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: scale(0.9); }
      to { opacity: 1; transform: scale(1); }
    }

    /* Logo */
    .logo {
      height: 50px;
      margin-bottom: 15px;
      filter: drop-shadow(0 0 10px rgba(52, 211, 153, 0.5));
    }
  </style>
</head>

<body>

  <!-- Background Effects -->
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>

  <!-- Card -->
  <div class="card">
    <img src="/assets/images/logo.png" class="logo" alt="VendBoost Logo">

    <h2>Connect WhatsApp</h2>
    <p class="vendor-id">Vendor ID: <%= vendorId %></p>

    <div id="status-container"></div>
  </div>

<script>
  const vendorId = "<%= vendorId %>";

  async function fetchStatus() {
    try {
      const res = await fetch(`/dashboard/whatsapp-status`, {
        credentials: 'include'
      });
      const data = await res.json();

      const container = document.getElementById("status-container");

      if (data.status === "connected") {
        container.innerHTML = `<p class="status success">✅ WhatsApp connected! Redirecting...</p>`;
        setTimeout(() => { window.location.href = "/dashboard"; }, 1000);
        return;
      }

      if (data.status === "qr" && data.qr) {
        container.innerHTML = `
          <p class="status">📱 Scan this QR Code with WhatsApp</p>
          <img src="${data.qr}" class="qr" />
        `;
        return;
      }

      if (data.status === "initializing") {
        container.innerHTML = `
          <div class="spinner"></div>
          <p class="status loading">Initializing WhatsApp session...</p>
        `;
        return;
      }

      if (data.status === "error" || data.status === "auth_failed") {
        container.innerHTML = `
          <p class="status error">❌ Connection failed. Please try again.</p>
          <button class="btn" onclick="window.location.reload()">Retry</button>
        `;
        return;
      }

      if (data.status === "disconnected" || data.status === "not_initialized") {
        container.innerHTML = `
          <p class="status">⚠️ WhatsApp session not connected.</p>
          <button class="btn" onclick="window.location.reload()">Reconnect</button>
        `;
        return;
      }

    } catch (err) {
      console.error("Fetch status error:", err);
    }
  }

  setInterval(fetchStatus, 2000);
  fetchStatus();
</script>

</body>
</html>