<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %> - VendBoost</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f4f6f9;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .card {
      background: white;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 5px 20px rgba(0,0,0,0.1);
      width: 400px;
      text-align: center;
    }

    h2 {
      margin-bottom: 10px;
    }

    .status {
      margin-top: 20px;
      font-size: 16px;
    }

    .success { color: green; }
    .error { color: red; }
    .loading { color: #555; }

    .spinner {
      margin: 20px auto;
      width: 40px;
      height: 40px;
      border: 4px solid #ccc;
      border-top: 4px solid #25D366;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .btn {
      margin-top: 20px;
      padding: 10px 15px;
      border: none;
      background: #25D366;
      color: white;
      border-radius: 6px;
      cursor: pointer;
    }

    .btn:hover { background: #1da851; }

    img.qr { margin-top: 15px; width: 200px; }
  </style>
</head>
<body>

  <div class="card">
    <h2>Connect WhatsApp</h2>
    <p>Vendor ID: <%= vendorId %></p>

    <div id="status-container">
      <!-- Status & QR will appear here -->
    </div>

  </div>

<script>
  const vendorId = "<%= vendorId %>";

  async function fetchStatus() {
    try {
      const res = await fetch(`/vendor/whatsapp-status`, {
        credentials: 'include'
      });
      const data = await res.json();

      const container = document.getElementById("status-container");

      // 🔹 CONNECTED → redirect
      if (data.status === "connected") {
        container.innerHTML = `<p class="status success">✅ WhatsApp connected! Redirecting...</p>`;
        setTimeout(() => { window.location.href = "/dashboard"; }, 1000);
        return;
      }

      // 🔹 SHOW QR
      if (data.status === "qr" && data.qr) {
        container.innerHTML = `
          <p class="status">📱 Scan this QR Code with WhatsApp</p>
          <img src="${data.qr}" class="qr" />
        `;
        return;
      }

      // 🔹 INITIALIZING
      if (data.status === "initializing") {
        container.innerHTML = `
          <div class="spinner"></div>
          <p class="status loading">Initializing WhatsApp session...</p>
        `;
        return;
      }

      // 🔹 ERROR / AUTH FAILURE
      if (data.status === "error" || data.status === "auth_failed") {
        container.innerHTML = `
          <p class="status error">❌ Connection failed. Please try again.</p>
          <button class="btn" onclick="window.location.reload()">Retry</button>
        `;
        return;
      }

      // 🔹 DISCONNECTED / NOT INITIALIZED
      if (data.status === "disconnected" || data.status === "not_initialized") {
        container.innerHTML = `
          <p class="status">⚠️ WhatsApp session not connected.</p>
          <button class="btn" onclick="window.location.reload()">Reconnect</button>
        `;
        return;
      }

    } catch (err) {
      console.error("Fetch status error:", err);
    }
  }

  // Poll every 2 seconds
  setInterval(fetchStatus, 2000);

  // Initial fetch
  fetchStatus();
</script>

</body>
</html>